# experiments/

# Commissions — external work, own repos, not submodules
commissions/

# Sūtra relay clone (per-project harness, local cursor)
.sutra/

# Sutradhar companion workspace (warp deposit, ephemeral state)
.sutradhar/

# First-boot sentinel (bootstrap.sh drops this; agent deletes after setup)
.first-boot

modules/sutradhar/.cpcache/

